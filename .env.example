# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- LLM provider (pick ONE block) ---

# Option A: Anthropic API direkt
ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# Option B: AWS Bedrock via API key (kein AWS Sigv4 / boto3)
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_REGION=us-east-1
# CLAUDE_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# LLM_PROVIDER kann anthropic|bedrock sein; sonst Auto-Detect (bedrock falls
# AWS_BEARER_TOKEN_BEDROCK gesetzt, sonst anthropic).
# LLM_PROVIDER=

# --- Optional: kleinanzeigen-bot fürs Direkt-Schalten ---
# KLEINANZEIGEN_BOT_CMD=pdm -p /Users/you/tools/kleinanzeigen-bot run app
# KLEINANZEIGEN_USERNAME=deine@mail.de
# KLEINANZEIGEN_PASSWORD=
# KLEINANZEIGEN_CONFIG=/Users/you/.kleinanzeigen-agent/config.yaml
# KLEINANZEIGEN_WORK_DIR=/Users/you/.kleinanzeigen-agent/ads
# KLEINANZEIGEN_SHIPPING=PICKUP
